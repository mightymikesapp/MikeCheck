# IMPORTANT: This is an EXAMPLE template only. DO NOT commit actual secrets to git!
#
# For production deployments, use one of these approaches:
#
# 1. Kubernetes Secrets (via kubectl create secret):
#    kubectl create secret generic legal-research-secrets \
#      --from-literal=COURTLISTENER_API_KEY=$YOUR_KEY \
#      -n legal-research
#
# 2. Sealed Secrets (https://github.com/bitnami-labs/sealed-secrets):
#    echo -n $YOUR_KEY | kubectl create secret generic legal-research-secrets \
#      --dry-run=client --from-file=COURTLISTENER_API_KEY=/dev/stdin -o yaml | \
#      kubeseal -o yaml > k8s/secret-sealed.yaml
#
# 3. External Secrets Operator (AWS Secrets Manager, HashiCorp Vault, etc.)
#
# Below is the format if you choose to create secrets manually:

apiVersion: v1
kind: Secret
metadata:
  name: legal-research-secrets
  namespace: legal-research
  labels:
    app.kubernetes.io/name: legal-research-mcp
type: Opaque
stringData:
  # CourtListener API Key (from https://www.courtlistener.com/api/rest/v4/)
  # DO NOT commit the actual key to version control!
  COURTLISTENER_API_KEY: "PLACEHOLDER_YOUR_API_KEY_HERE"
