# Legal Research Assistant MCP - Environment Configuration
# Copy this file to .env and update values for your environment
# Lines starting with # are comments and will be ignored

################################################################################
# COURTLISTENER API - REQUIRED CONFIGURATION
################################################################################

# API key from CourtListener (Free Law Project)
# Get your free key at: https://www.courtlistener.com/api/rest/v4/
# Supports both COURTLISTENER_API_KEY and COURT_LISTENER_API_KEY environment variables
COURTLISTENER_API_KEY=your_free_law_project_api_key_here

# Base URL for CourtListener API (do not change unless using custom instance)
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4/

# CourtListener MCP server URL (for internal routing)
COURTLISTENER_MCP_URL=http://localhost:8000/mcp/

################################################################################
# PERFORMANCE MODE - Choose based on your use case
################################################################################

# Deployment profile: light | standard | heavy
# - light:    Fast responses, minimal API usage (max 25 citing cases, 3 full-text fetches)
# - standard: Balanced (max 100 citing cases, 10 full-text fetches) [DEFAULT]
# - heavy:    Deep analysis, comprehensive results (max 200 citing cases, 25 full-text fetches)
MODE=standard

################################################################################
# TIMEOUT & RETRY CONFIGURATION
################################################################################

# Total request timeout for all CourtListener API calls (seconds)
COURTLISTENER_TIMEOUT=30

# Connection timeout (how long to wait to establish connection)
COURTLISTENER_CONNECT_TIMEOUT=10

# Read timeout (how long to wait for response after connection established)
COURTLISTENER_READ_TIMEOUT=60

# Number of retry attempts for failed API requests
COURTLISTENER_RETRY_ATTEMPTS=3

# Initial backoff multiplier for exponential backoff (seconds)
# Actual backoff: multiplier * (2 ^ attempt_number)
COURTLISTENER_RETRY_BACKOFF=1.0

################################################################################
# CACHING CONFIGURATION
################################################################################

# Master switch to enable/disable all caching
CACHE_ENABLED=true

# Root directory for all cache data
CACHE_DIR=.cache

# Directory for CourtListener API response cache
COURTLISTENER_CACHE_DIR=.cache/courtlistener

# Directory for citation network data
NETWORK_CACHE_DIR=./citation_networks

# Cache TTL (Time To Live) in seconds
# Format: SECONDS (e.g., 86400 = 24 hours, 604800 = 7 days)

# Metadata cache (case names, citations, basic info)
# Default: 86400 = 24 hours
COURTLISTENER_TTL_METADATA=86400

# Opinion text cache (full text of court opinions)
# Default: 604800 = 7 days
COURTLISTENER_TTL_TEXT=604800

# Search results cache
# Default: 3600 = 1 hour
COURTLISTENER_TTL_SEARCH=3600

# Enable/disable search result caching specifically
COURTLISTENER_SEARCH_CACHE_ENABLED=true

################################################################################
# CORS CONFIGURATION (Cross-Origin Resource Sharing)
################################################################################

# Comma-separated list of allowed origins (domains that can access the API)
# Default allows only localhost (safe for local development)
# For production, specify exact domain(s)
# Examples:
#   localhost: "http://localhost:3000,http://localhost:8000"
#   production: "https://myapp.example.com"
#   wildcard: "*" (NOT RECOMMENDED - allows any origin)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Allow credentials (cookies, authorization headers) in cross-origin requests
CORS_CREDENTIALS=true

# Allowed HTTP methods for CORS
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed headers in CORS requests
# "*" allows all headers (safe for this API)
CORS_HEADERS=*

################################################################################
# SECURITY HEADERS CONFIGURATION
################################################################################

# Enable HSTS (HTTP Strict Transport Security)
# Forces HTTPS-only connections (set to true in production)
ENABLE_HSTS=false

# HSTS max-age in seconds (how long browser remembers to use HTTPS)
# 31536000 = 1 year (recommended production value)
HSTS_MAX_AGE=31536000

# Enable Content Security Policy (CSP)
# Prevents inline scripts and external resource loading
ENABLE_CSP=true

# CSP policy directive
# Restricts where scripts, styles, and other resources can be loaded from
# Production recommendation: "default-src 'self'; script-src 'self'"
# Current: allows inline scripts (for development/templates)
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"

################################################################################
# LOGGING CONFIGURATION
################################################################################

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: json (structured logging) or text
LOG_FORMAT=json

# Date format for log timestamps
LOG_DATE_FORMAT="%Y-%m-%d %H:%M:%S"

# Enable debug mode (more verbose logging, may expose sensitive info)
DEBUG=false

################################################################################
# TREATMENT ANALYSIS CONFIGURATION
################################################################################

# Minimum confidence threshold for case validity assessments (0.0-1.0)
# Higher = stricter filtering, fewer weak signals
# Default: 0.7 (70% confidence)
TREATMENT_CONFIDENCE_THRESHOLD=0.7

# Strategy for fetching full opinion text
# Options:
#   - always:       Fetch full text for every case (slowest, most accurate)
#   - smart:        Fetch only if initial snippet analysis shows negative signals (recommended)
#   - negative_only: Fetch only for cases with negative signals
#   - never:        Never fetch full text, use snippets only (fastest)
FETCH_FULL_TEXT_STRATEGY=smart

# Maximum number of citing cases to analyze per request
MAX_CITING_CASES=100

# Maximum number of full opinion texts to fetch in a single analysis
MAX_FULL_TEXT_FETCHES=10

# Enable ML-based treatment classifier for high-ambiguity cases
# When enabled, uses a Transformer model (zero-shot classification) to refine
# treatment signals when regex-based classification has low confidence
# Requires: transformers library (included in dependencies)
# Default: false (disabled - regex-only for speed)
# WARNING: Enabling this will download ~400MB model on first use
ENABLE_ML_CLASSIFIER=false

# Confidence threshold below which ML classifier is triggered
# If regex classifier confidence < this threshold, ML classifier refines the result
# Range: 0.0-1.0, Default: 0.6 (60% confidence)
ML_CLASSIFIER_CONFIDENCE_THRESHOLD=0.6

################################################################################
# CITATION NETWORK CONFIGURATION
################################################################################

# Maximum depth for citation network graph traversal (1-4)
# Deeper = more comprehensive but slower and uses more API calls
# Default: 3
NETWORK_MAX_DEPTH=3

# Maximum total nodes allowed in a single citation network request
# Prevents memory exhaustion and slow response times
# Default: 300
MAX_TOTAL_NETWORK_NODES=300

# Maximum number of quotes that can be verified in a single batch request
# Default: 50
MAX_QUOTES_PER_BATCH=50

################################################################################
# AUTHENTICATION CONFIGURATION
################################################################################

# Enable API key authentication for protected endpoints
# When enabled, all requests (except /health, /metrics) require a valid API key
# If set to true, API_KEYS must contain at least one key; startup will fail otherwise
# Default: false (disabled for development)
ENABLE_API_KEY_AUTH=false

# Comma-separated list of valid API keys
# Format: key1,key2,key3 (must be non-empty when ENABLE_API_KEY_AUTH=true)
# Leave empty only if authentication is disabled
# Application will exit during startup if ENABLE_API_KEY_AUTH=true and this list is empty
# Example: "sk_test_123abc,sk_test_456def,sk_prod_789ghi"
API_KEYS=

# Authentication methods:
# 1. Authorization header: Authorization: Bearer YOUR_KEY
# 2. X-API-Key header: X-API-Key: YOUR_KEY
# 3. Query parameter: ?api_key=YOUR_KEY (less secure, for development only)

################################################################################
# RATE LIMITING CONFIGURATION
################################################################################

# Enable rate limiting for API endpoints
# When enabled, enforces per-endpoint limits to prevent abuse
# Default: true (enabled)
ENABLE_RATE_LIMITING=true

# Default rate limit for all endpoints
# Format: "N/minute", "N/hour", "N/day"
# Examples: "100/minute", "10/hour"
# Default: "100/minute"
RATE_LIMIT_DEFAULT=100/minute

# Rate limit for treatment analysis endpoints (/herding/analyze)
# These endpoints are compute-intensive, so limits are stricter
# Default: "5/minute"
RATE_LIMIT_TREATMENT_ANALYSIS=5/minute

# Rate limit for bulk operation endpoints (/*/bulk)
# Bulk endpoints process multiple items, so limits are very strict
# Default: "2/minute"
RATE_LIMIT_BULK_OPERATIONS=2/minute

# Rate limit for semantic search endpoints (/search/semantic)
# Search is moderately expensive
# Default: "20/minute"
RATE_LIMIT_SEMANTIC_SEARCH=20/minute

# Rate limiting uses:
# - API key as primary identifier (if authenticated)
# - IP address as fallback (if not authenticated)
# Limits are per-identifier, per-time-window

################################################################################
# MCP SERVER CONFIGURATION
################################################################################

# Port for MCP server (if running standalone MCP mode)
MCP_PORT=8001

################################################################################
# DEPLOYMENT NOTES
################################################################################

# For local development: Use default values above
# For Docker/K8s: Override via environment variables or ConfigMap
# For production: Use secrets management (Kubernetes Secrets, AWS Secrets Manager, etc.)
#
# Example Docker override:
#   docker run -e COURTLISTENER_API_KEY=$KEY -e MODE=heavy myapp:latest
#
# Example Kubernetes override:
#   kubectl set env deployment/legal-research-mcp COURTLISTENER_API_KEY=$KEY
